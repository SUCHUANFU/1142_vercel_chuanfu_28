{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    // "ignoreDeprecations": "6.0",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts",
    "src/app/(demo)/_assets/wrapper/Navbar_28.jsx",
    "src/app/(demo)/_assets/wrapper/Grocery_28.jsx",
    "src/app/(demo)/_assets/wrapper/Blog2_28.jsx",
    "src/app/(demo)/grocery_28/page.tsx",
    "src/app/(demo)/grocery_28/_components/SingleItem_28.tsx",
    "src/app/(demo)/grocery_28/_components/Items_28.tsx",
    "src/app/(demo)/grocery_28/_components/Form_28.tsx",
    "src/app/(demo)/grocery_db28/_components/SingleItem_28.jsx",
    "src/app/(demo)/grocery_db28/_components/Form_28x",
    "src/app/(demo)/grocery_db28/page.jsx"
  ],
  "exclude": [
    "node_modules",
    "startup14", // <--- 補上這一行*，確保整個 startup14 目錄被忽略
    "**/startup14/**/*" //<--- 以及這一行，確保子目錄也忽略
  ]
}
